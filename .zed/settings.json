{
  "wrap_guides": [100],
  "formatter": [{
    "external": {
      "command": "dprint",
      "arguments": ["fmt", "--stdin", "{buffer_path}"]
    }
  }],
  "languages": {
    "TypeScript": { "language_servers": ["deno"] },
    "JavaScript": { "language_servers": ["deno"] },
    "JSON": { "wrap_guides": [120] },
    "JSONC": { "wrap_guides": [120] },
    "TOML": { "wrap_guides": [140] }
  },
  "lsp": {
    "deno": { "settings": { "deno": { "enable": true } } },
    "json-language-server": {
      "settings": {
        "json": {
          "schemas": [{
            "fileMatch": ["deno.json", "deno.jsonc"],
            "url": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json"
          }, {
            "fileMatch": ["package.json"],
            "url": "https://www.schemastore.org/package"
          }]
        }
      }
    },
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "target": "wasm32-unknown-unknown",
          "features": ["schema"]
        }
      }
    }
  }
}
